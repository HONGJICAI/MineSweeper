{
  "name": "caiji-games",
  "private": true,
  "packageManager": "pnpm@10.13.0",
  "scripts": {
    "build": "pnpm -r --parallel run build",
    "build:shared": "pnpm --filter shared-* run build",
    "build:shared-utils": "pnpm --filter @caiji-games/shared-utils run build",
    "build:shared-hooks": "pnpm --filter @caiji-games/shared-hooks run build",
    "build:shared-ui": "pnpm --filter @caiji-games/shared-ui run build",
    "build:web": "pnpm -r --parallel run build:web",
    "build:desktop": "pnpm -r --parallel run build:desktop",
    "tauri": "pnpm -r run tauri",
    "tauri:ms": "pnpm --filter minesweeper tauri:ms"
  }
}
