{
  "name": "minesweeper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview --port 5174",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "build:web": "cross-env VITE_PLATFORM=web vite build",
    "build:desktop": "cross-env VITE_PLATFORM=desktop vite build",
    "tauri": "tauri",
    "tauri:icons": "tauri icon public/128x128@2x.png",
    "tauri:steam": "pnpm tauri build --config src-tauri/tauri.steam.conf.json && node packSteam.cjs",
    "tauri:ms": "npx tauri build -- --no-bundle && npx tauri bundle -- --config src-tauri/tauri.microsoftstore.conf.json",
    "tauri:android:init": "npx tauri android init",
    "tauri:android:dev": "npx tauri android dev",
    "build:android": "cross-env VITE_PLATFORM=mobile vite build && npx tauri android build --aab",
    "build:android:apk": "cross-env VITE_PLATFORM=mobile vite build && npx tauri android build --apk",
    "postinstall": "pnpm run tauri:icons"
  },
  "dependencies": {
    "@caiji-games/minesweeper-core": "workspace:*",
    "@caiji-games/shared-state": "workspace:*",
    "@caiji-games/shared-ui": "workspace:*",
    "@tauri-apps/api": "catalog:"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@tauri-apps/cli": "catalog:",
    "archiver": "^7.0.1",
    "cross-env": "catalog:",
    "fs-extra": "^11.3.1",
    "svelte": "catalog:",
    "svelte-check": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-pwa": "catalog:"
  }
}
