{
  "name": "sliding-puzzle",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "build:web": "cross-env VITE_PLATFORM=web vite build",
    "build:desktop": "cross-env VITE_PLATFORM=desktop vite build",
    "tauri": "tauri",
    "tauri:icons": "tauri icon public/128x128@2x.png",
    "tauri:ms": "npx tauri build -- --no-bundle && npx tauri bundle -- --config src-tauri/tauri.microsoftstore.conf.json",
    "tauri:android:init": "npx tauri android init",
    "tauri:android:dev": "npx tauri android dev",
    "build:android": "cross-env VITE_PLATFORM=mobile vite build && npx tauri android build --apk",
    "postinstall": "pnpm run tauri:icons"
  },
  "dependencies": {
    "@caiji-games/shared-ui": "workspace:*",
    "@caiji-games/sliding-puzzle-core": "workspace:*",
    "@tauri-apps/api": "catalog:"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@tauri-apps/cli": "catalog:",
    "@types/node": "^20",
    "cross-env": "catalog:",
    "svelte": "catalog:",
    "svelte-check": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "packageManager": "pnpm@10.13.0"
}
